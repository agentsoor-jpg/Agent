<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>AI Engineering OS v3.0</title>
<style>
:root{--bg:#0d1117;--surface:#161b22;--surface2:#1f2937;--border:#30363d;--text:#e6edf3;--text2:#8b949e;--accent:#58a6ff;--green:#3fb950;--red:#f85149;--yellow:#d29922;--purple:#a371f7;--orange:#f0883e;}
.light{--bg:#f6f8fa;--surface:#fff;--surface2:#f3f4f6;--border:#d0d7de;--text:#1f2328;--text2:#57606a;--accent:#0969da;--green:#1a7f37;--red:#cf222e;--yellow:#9a6700;--purple:#8250df;--orange:#bc4c00;}
*{box-sizing:border-box;margin:0;padding:0;}
body{font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',sans-serif;background:var(--bg);color:var(--text);min-height:100vh;font-size:14px;}
.layout{display:grid;grid-template-columns:220px 1fr;grid-template-rows:52px 1fr;height:100vh;}
@media(max-width:768px){.layout{grid-template-columns:1fr;grid-template-rows:52px auto 1fr;}.sidebar{display:none;}.sidebar.open{display:block;position:fixed;top:52px;left:0;right:0;z-index:100;height:auto;max-height:60vh;overflow-y:auto;border-right:none;border-bottom:1px solid var(--border);}.mobile-menu-btn{display:flex!important;}}
.topbar{grid-column:1/-1;background:var(--surface);border-bottom:1px solid var(--border);display:flex;align-items:center;padding:0 16px;gap:12px;z-index:10;}
.sidebar{background:var(--surface);border-right:1px solid var(--border);overflow-y:auto;padding:8px 0;}
.main{overflow-y:auto;padding:20px;background:var(--bg);}
.logo{font-weight:700;font-size:15px;color:var(--accent);display:flex;align-items:center;gap:8px;flex-shrink:0;}
.logo-icon{width:28px;height:28px;background:linear-gradient(135deg,var(--accent),var(--purple));border-radius:6px;display:flex;align-items:center;justify-content:center;font-size:14px;}
.topbar-right{display:flex;align-items:center;gap:10px;margin-left:auto;}
.version-badge{background:var(--surface2);border:1px solid var(--border);color:var(--accent);font-size:11px;padding:2px 8px;border-radius:10px;font-weight:600;}
.system-status{display:flex;align-items:center;gap:6px;font-size:12px;color:var(--text2);}
.dot{width:8px;height:8px;border-radius:50%;background:var(--green);animation:pulse 2s infinite;}
.dot.offline{background:var(--red);animation:none;}
@keyframes pulse{0%,100%{opacity:1}50%{opacity:.5}}
.btn{background:var(--accent);color:white;border:none;padding:6px 14px;border-radius:6px;cursor:pointer;font-size:12px;font-weight:600;transition:all .15s;}
.btn:hover{opacity:.88;}
.btn-sm{padding:4px 10px;font-size:11px;}
.btn-outline{background:none;border:1px solid var(--border);color:var(--text);padding:6px 12px;border-radius:6px;cursor:pointer;font-size:12px;transition:all .15s;}
.btn-outline:hover{background:var(--surface2);}
.btn-ghost{background:none;border:none;color:var(--text2);padding:4px 8px;border-radius:6px;cursor:pointer;font-size:12px;transition:all .15s;}
.btn-ghost:hover{background:var(--surface2);color:var(--text);}
.mobile-menu-btn{display:none;background:none;border:1px solid var(--border);color:var(--text);padding:6px 10px;border-radius:6px;cursor:pointer;font-size:16px;}
.nav-label{font-size:10px;font-weight:600;color:var(--text2);text-transform:uppercase;letter-spacing:.8px;padding:8px 12px 4px;}
.nav-item{display:flex;align-items:center;gap:8px;padding:7px 12px;border-radius:6px;cursor:pointer;font-size:13px;color:var(--text2);transition:all .15s;border:none;background:none;width:100%;text-align:left;position:relative;}
.nav-item:hover{background:var(--surface2);color:var(--text);}
.nav-item.active{background:rgba(88,166,255,.12);color:var(--accent);}
.nav-badge{margin-left:auto;background:var(--accent);color:white;font-size:10px;padding:1px 6px;border-radius:10px;font-weight:600;}
.nav-pulse{width:6px;height:6px;border-radius:50%;background:var(--green);animation:pulse 1.5s infinite;margin-left:auto;}
.panel{display:none;animation:fadeIn .15s ease;}
.panel.active{display:block;}
@keyframes fadeIn{from{opacity:0;transform:translateY(4px)}to{opacity:1;transform:none}}
.page-title{font-size:20px;font-weight:700;margin-bottom:4px;}
.page-sub{color:var(--text2);font-size:13px;margin-bottom:20px;}
.grid{display:grid;gap:16px;}
.grid-2{grid-template-columns:repeat(2,1fr);}
.grid-3{grid-template-columns:repeat(3,1fr);}
.grid-4{grid-template-columns:repeat(4,1fr);}
@media(max-width:900px){.grid-4,.grid-3{grid-template-columns:repeat(2,1fr);}.grid-2{grid-template-columns:1fr;}}
@media(max-width:600px){.grid-4,.grid-3,.grid-2{grid-template-columns:1fr;}}
.card{background:var(--surface);border:1px solid var(--border);border-radius:10px;padding:16px;}
.card-title{font-size:12px;font-weight:600;color:var(--text2);text-transform:uppercase;letter-spacing:.6px;margin-bottom:12px;display:flex;align-items:center;justify-content:space-between;}
.stat-val{font-size:26px;font-weight:700;color:var(--text);margin:4px 0;}
.stat-sub{font-size:12px;color:var(--text2);}
.agent-card{border:1px solid var(--border);border-radius:8px;padding:14px;transition:all .3s;}
.agent-card.working{border-color:var(--accent);box-shadow:0 0 0 2px rgba(88,166,255,.15);animation:agentPulse 1.5s infinite;}
@keyframes agentPulse{0%,100%{box-shadow:0 0 0 2px rgba(88,166,255,.15)}50%{box-shadow:0 0 0 6px rgba(88,166,255,.05)}}
.agent-header{display:flex;align-items:center;justify-content:space-between;margin-bottom:8px;}
.agent-name{font-weight:600;font-size:14px;}
.status-pill{display:inline-flex;align-items:center;gap:5px;padding:3px 8px;border-radius:20px;font-size:11px;font-weight:600;}
.status-pill.online{background:rgba(63,185,80,.15);color:var(--green);}
.status-pill.offline{background:rgba(248,81,73,.12);color:var(--red);}
.status-pill.working{background:rgba(88,166,255,.15);color:var(--accent);}
.status-pill.idle{background:rgba(139,148,158,.1);color:var(--text2);}
.agent-caps{display:flex;flex-wrap:wrap;gap:4px;margin-top:6px;}
.cap-tag{background:var(--surface2);border:1px solid var(--border);color:var(--text2);font-size:10px;padding:2px 7px;border-radius:12px;}
.workflow-form{display:grid;gap:12px;margin-bottom:16px;}
.form-row{display:grid;grid-template-columns:1fr 1fr;gap:12px;}
@media(max-width:600px){.form-row{grid-template-columns:1fr;}}
label{font-size:12px;font-weight:600;color:var(--text2);display:block;margin-bottom:4px;}
textarea,input,select{width:100%;background:var(--surface2);border:1px solid var(--border);color:var(--text);border-radius:6px;padding:8px 10px;font-size:13px;font-family:inherit;resize:vertical;outline:none;transition:border-color .15s;}
textarea:focus,input:focus,select:focus{border-color:var(--accent);}
.phase-bar{background:var(--surface);border:1px solid var(--border);border-radius:10px;padding:16px;margin-bottom:16px;}
.phase-title{font-weight:600;margin-bottom:10px;display:flex;align-items:center;justify-content:space-between;}
.phase-steps{display:flex;gap:0;}
.phase-step{flex:1;text-align:center;position:relative;}
.phase-step:not(:last-child)::after{content:'';position:absolute;top:13px;right:-50%;width:100%;height:2px;background:var(--border);z-index:0;}
.phase-step.done::after{background:var(--green);}
.phase-step.active::after{background:var(--accent);}
.phase-dot{width:26px;height:26px;border-radius:50%;border:2px solid var(--border);background:var(--surface2);margin:0 auto 4px;display:flex;align-items:center;justify-content:center;font-size:11px;font-weight:700;position:relative;z-index:1;transition:all .3s;}
.phase-step.done .phase-dot{border-color:var(--green);background:var(--green);color:white;}
.phase-step.active .phase-dot{border-color:var(--accent);background:var(--accent);color:white;animation:pulse 1.5s infinite;}
.phase-label{font-size:10px;color:var(--text2);text-transform:uppercase;letter-spacing:.5px;}
.step-log{background:var(--bg);border:1px solid var(--border);border-radius:8px;padding:12px;max-height:260px;overflow-y:auto;font-family:'SF Mono',Monaco,monospace;font-size:12px;line-height:1.7;}
.log-entry{padding:2px 0;display:flex;gap:8px;}
.log-time{color:var(--text2);flex-shrink:0;}
.log-msg{color:var(--text);}
.log-msg.success{color:var(--green);}
.log-msg.error{color:var(--red);}
.log-msg.warn{color:var(--yellow);}
.log-msg.info{color:var(--accent);}
.elapsed{font-family:monospace;color:var(--accent);font-weight:700;}
.wf-row{display:flex;align-items:center;gap:10px;padding:10px;border-bottom:1px solid var(--border);flex-wrap:wrap;}
.wf-row:last-child{border-bottom:none;}
.wf-id{font-family:monospace;font-size:11px;color:var(--text2);}
.wf-type{font-weight:600;font-size:13px;}
.wf-status{font-size:11px;font-weight:600;padding:2px 8px;border-radius:10px;}
.wf-status.completed{background:rgba(63,185,80,.15);color:var(--green);}
.wf-status.running{background:rgba(88,166,255,.15);color:var(--accent);}
.wf-status.failed{background:rgba(248,81,73,.12);color:var(--red);}
.wf-status.interrupted{background:rgba(210,153,34,.12);color:var(--yellow);}
.terminal{background:#0d0d0d;border:1px solid #333;border-radius:8px;font-family:'SF Mono',Monaco,monospace;font-size:12px;line-height:1.7;height:320px;display:flex;flex-direction:column;}
.terminal-bar{background:#1a1a1a;padding:8px 12px;border-bottom:1px solid #333;display:flex;align-items:center;gap:8px;flex-shrink:0;}
.term-dots{display:flex;gap:5px;}
.term-dot{width:10px;height:10px;border-radius:50%;}
.term-output{padding:10px;overflow-y:auto;flex:1;color:#a8b5c8;}
.term-output .cmd{color:#58a6ff;}
.term-output .ok{color:#3fb950;}
.term-output .err{color:#f85149;}
.term-input-row{display:flex;border-top:1px solid #333;flex-shrink:0;}
.term-input{flex:1;background:transparent;border:none;color:#e6edf3;padding:8px 12px;font-family:inherit;font-size:12px;outline:none;}
.term-prompt{padding:8px 0 8px 12px;color:#3fb950;font-family:monospace;font-size:12px;}
.progress-bar{height:4px;background:var(--border);border-radius:2px;overflow:hidden;margin:8px 0;}
.progress-fill{height:100%;background:var(--accent);border-radius:2px;transition:width .4s ease;}
.progress-fill.green{background:var(--green);}
.plan-card{background:var(--surface2);border:1px solid var(--border);border-radius:8px;padding:12px;margin-bottom:8px;}
.plan-phase{display:flex;align-items:center;gap:10px;padding:8px 0;border-bottom:1px solid var(--border);}
.plan-phase:last-child{border-bottom:none;}
.plan-agent{font-size:11px;font-weight:700;padding:2px 7px;border-radius:4px;text-transform:uppercase;}
.agent-bolt{background:rgba(240,136,62,.15);color:var(--orange);}
.agent-aider{background:rgba(163,113,247,.15);color:var(--purple);}
.agent-openhands{background:rgba(88,166,255,.15);color:var(--accent);}
.agent-replit{background:rgba(63,185,80,.15);color:var(--green);}
.memory-card{background:var(--surface2);border:1px solid var(--border);border-radius:8px;padding:12px;margin-bottom:8px;cursor:pointer;transition:all .15s;}
.memory-card:hover{border-color:var(--accent);}
.memory-name{font-weight:600;margin-bottom:4px;}
.memory-desc{font-size:12px;color:var(--text2);white-space:nowrap;overflow:hidden;text-overflow:ellipsis;}
.memory-meta{display:flex;gap:8px;margin-top:6px;flex-wrap:wrap;}
.meta-tag{background:var(--surface);border:1px solid var(--border);font-size:10px;padding:1px 6px;border-radius:10px;color:var(--text2);}
.sim-score{margin-left:auto;font-size:11px;font-weight:700;color:var(--accent);}
.verify-row{display:flex;align-items:center;justify-content:space-between;padding:10px 0;border-bottom:1px solid var(--border);}
.verify-row:last-child{border-bottom:none;}
.verify-label{font-size:13px;font-weight:500;}
.verify-result{font-size:12px;font-weight:700;}
.verify-result.pass{color:var(--green);}
.verify-result.fail{color:var(--red);}
.verify-result.skip{color:var(--text2);}
.completeness-bar{border:1px solid var(--border);border-radius:8px;padding:14px;}
.pct-ring{width:80px;height:80px;margin:0 auto 8px;}
.pct-text{text-align:center;font-size:24px;font-weight:700;}
.info-row{display:flex;gap:10px;padding:6px 0;border-bottom:1px solid var(--border);font-size:13px;}
.info-row:last-child{border-bottom:none;}
.info-key{color:var(--text2);width:140px;flex-shrink:0;}
.info-val{font-weight:500;}
.toast{position:fixed;bottom:20px;right:20px;background:var(--surface);border:1px solid var(--border);color:var(--text);padding:12px 16px;border-radius:8px;font-size:13px;z-index:1000;transform:translateY(100px);opacity:0;transition:all .25s;max-width:300px;}
.toast.show{transform:none;opacity:1;}
.toast.success{border-color:var(--green);}
.toast.error{border-color:var(--red);}
.sse-indicator{display:flex;align-items:center;gap:5px;font-size:11px;color:var(--text2);}
.sse-dot{width:6px;height:6px;border-radius:50%;background:var(--text2);}
.sse-dot.connected{background:var(--green);animation:pulse 1.5s infinite;}
.search-row{display:flex;gap:8px;margin-bottom:12px;}
.search-row input{flex:1;}
.section-tabs{display:flex;gap:4px;margin-bottom:16px;border-bottom:1px solid var(--border);padding-bottom:0;}
.tab{padding:8px 14px;font-size:13px;font-weight:500;color:var(--text2);cursor:pointer;border-bottom:2px solid transparent;margin-bottom:-1px;transition:all .15s;}
.tab:hover{color:var(--text);}
.tab.active{color:var(--accent);border-bottom-color:var(--accent);}
.empty-state{text-align:center;padding:40px 20px;color:var(--text2);}
.empty-state .icon{font-size:36px;margin-bottom:12px;}
.env-row{display:flex;gap:8px;margin-bottom:8px;align-items:center;}
.env-key{width:180px;flex-shrink:0;}
.env-val{flex:1;}
.env-del{color:var(--red);cursor:pointer;padding:4px 8px;border:none;background:none;font-size:14px;}
</style>
</head>
<body>
<div class="layout">

<!-- Topbar -->
<div class="topbar">
  <button class="mobile-menu-btn" onclick="toggleSidebar()">☰</button>
  <div class="logo">
    <div class="logo-icon">⚙</div>
    AI Engineering OS
  </div>
  <div class="version-badge">v3.0</div>
  <div style="display:flex;align-items:center;gap:8px;margin-left:12px;">
    <div class="sse-indicator"><div class="sse-dot" id="sseDot"></div><span id="sseLabel">SSE</span></div>
  </div>
  <div class="topbar-right">
    <div class="system-status">
      <div class="dot" id="healthDot"></div>
      <span id="healthLabel">Checking…</span>
    </div>
    <button class="btn-outline" onclick="toggleTheme()">🌓</button>
    <button class="btn btn-sm" onclick="refreshAll()">↻ Refresh</button>
  </div>
</div>

<!-- Sidebar -->
<div class="sidebar" id="sidebar">
  <div class="nav-label">Core</div>
  <button class="nav-item active" onclick="showPanel('overview')">📊 <span>Overview</span></button>
  <button class="nav-item" onclick="showPanel('agents')">🤖 <span>Agents</span></button>
  <button class="nav-item" onclick="showPanel('workflows')">⚡ <span>Workflows</span><span class="nav-badge" id="wfBadge">0</span></button>

  <div class="nav-label">v3.0 Features</div>
  <button class="nav-item" onclick="showPanel('plan')">🗺 <span>Plan</span></button>
  <button class="nav-item" onclick="showPanel('memory')">🧠 <span>Memory</span><span class="nav-badge" id="memBadge">0</span></button>
  <button class="nav-item" onclick="showPanel('verify')">✅ <span>Verify</span></button>

  <div class="nav-label">Tools</div>
  <button class="nav-item" onclick="showPanel('terminal')">⌨ <span>Terminal</span></button>
  <button class="nav-item" onclick="showPanel('files')">📁 <span>Files</span></button>
  <button class="nav-item" onclick="showPanel('config')">⚙ <span>Config</span></button>
</div>

<!-- Main -->
<div class="main">

<!-- ─── OVERVIEW ─────────────────────────────────────────────── -->
<div class="panel active" id="panel-overview">
  <div class="page-title">Overview</div>
  <div class="page-sub">AI Engineering OS v3.0 — Permanent memory · SSE streaming · 5-phase protocol</div>
  <div class="grid grid-4" style="margin-bottom:16px;">
    <div class="card"><div class="card-title">Workflows</div><div class="stat-val" id="ovWf">—</div><div class="stat-sub">total runs</div></div>
    <div class="card"><div class="card-title">Memory</div><div class="stat-val" id="ovMem">—</div><div class="stat-sub">projects stored</div></div>
    <div class="card"><div class="card-title">Agents</div><div class="stat-val" id="ovAgents">—</div><div class="stat-sub">online / 4</div></div>
    <div class="card"><div class="card-title">Queue</div><div class="stat-val" id="ovQueue">0</div><div class="stat-sub">tasks pending</div></div>
  </div>

  <div class="grid grid-2">
    <div class="card">
      <div class="card-title">Recent Workflows</div>
      <div id="recentWf"><div class="empty-state"><div class="icon">⚡</div>No workflows yet</div></div>
    </div>
    <div class="card">
      <div class="card-title">5-Phase Architecture</div>
      <div style="display:grid;gap:6px;">
        <div class="plan-phase"><span class="plan-agent agent-openhands">0</span><div><div style="font-weight:600;font-size:13px;">Context</div><div style="font-size:11px;color:var(--text2);">Load memory, find similar patterns</div></div></div>
        <div class="plan-phase"><span class="plan-agent agent-bolt">1</span><div><div style="font-weight:600;font-size:13px;">Plan</div><div style="font-size:11px;color:var(--text2);">Generate architecture plan, resolve deps</div></div></div>
        <div class="plan-phase"><span class="plan-agent agent-aider">2</span><div><div style="font-weight:600;font-size:13px;">Execute</div><div style="font-size:11px;color:var(--text2);">Run agents step-by-step with SSE</div></div></div>
        <div class="plan-phase"><span class="plan-agent agent-replit">3</span><div><div style="font-weight:600;font-size:13px;">Verify</div><div style="font-size:11px;color:var(--text2);">Build check, completeness, validation</div></div></div>
        <div class="plan-phase"><span class="plan-agent agent-openhands">4</span><div><div style="font-weight:600;font-size:13px;">Learn</div><div style="font-size:11px;color:var(--text2);">Store in permanent memory, update prefs</div></div></div>
      </div>
    </div>
  </div>
</div>

<!-- ─── AGENTS ────────────────────────────────────────────────── -->
<div class="panel" id="panel-agents">
  <div class="page-title">Agents</div>
  <div class="page-sub">Real-time status for all 4 AI agents</div>
  <div class="grid grid-2" id="agentGrid"></div>
</div>

<!-- ─── WORKFLOWS ─────────────────────────────────────────────── -->
<div class="panel" id="panel-workflows">
  <div class="page-title">Workflows</div>
  <div class="page-sub">Run the 5-phase execution protocol — watch progress live via SSE</div>

  <!-- 5-Phase progress bar -->
  <div class="phase-bar" id="phaseBar" style="display:none;">
    <div class="phase-title">
      <span id="phaseTitle">Executing workflow…</span>
      <span class="elapsed" id="elapsedTimer">0s</span>
    </div>
    <div class="phase-steps">
      <div class="phase-step" id="ps0"><div class="phase-dot">0</div><div class="phase-label">Context</div></div>
      <div class="phase-step" id="ps1"><div class="phase-dot">1</div><div class="phase-label">Plan</div></div>
      <div class="phase-step" id="ps2"><div class="phase-dot">2</div><div class="phase-label">Execute</div></div>
      <div class="phase-step" id="ps3"><div class="phase-dot">3</div><div class="phase-label">Verify</div></div>
      <div class="phase-step" id="ps4"><div class="phase-dot">4</div><div class="phase-label">Learn</div></div>
    </div>
    <div class="progress-bar" style="margin-top:14px;"><div class="progress-fill" id="wfProgressFill" style="width:0%"></div></div>
    <div style="font-size:11px;color:var(--text2);margin-top:4px;" id="wfProgressLabel">Initializing…</div>
  </div>

  <!-- SSE Step log -->
  <div id="sseLogWrap" style="display:none;margin-bottom:16px;">
    <div style="font-size:12px;font-weight:600;color:var(--text2);margin-bottom:6px;">Live Step Log</div>
    <div class="step-log" id="stepLog"></div>
  </div>

  <!-- Run form -->
  <div class="card">
    <div class="card-title">Run New Workflow</div>
    <div class="workflow-form">
      <div>
        <label>Workflow Type</label>
        <select id="wfType">
          <option value="full-app-generation">full-app-generation</option>
          <option value="refactoring">refactoring</option>
          <option value="bug-fixing">bug-fixing</option>
          <option value="prototyping">prototyping</option>
          <option value="code-review">code-review</option>
        </select>
      </div>
      <div>
        <label>Requirements</label>
        <textarea id="wfReq" rows="3" placeholder="Build a REST API with FastAPI, PostgreSQL, and JWT authentication"></textarea>
      </div>
      <div class="form-row">
        <div><label>Stack (optional)</label><input id="wfStack" placeholder="FastAPI, PostgreSQL, Redis"></div>
        <div><label>Features (comma-separated)</label><input id="wfFeatures" placeholder="auth, tasks, users"></div>
      </div>
      <div style="display:flex;gap:8px;">
        <button class="btn" onclick="runWorkflow()" id="runBtn">▶ Run Workflow</button>
        <button class="btn-outline" onclick="showPanel('plan')">🗺 Preview Plan First</button>
      </div>
    </div>
  </div>

  <!-- Workflow history -->
  <div class="card" style="margin-top:16px;">
    <div class="card-title">History <button class="btn-ghost btn-sm" onclick="loadWorkflows()">↻</button></div>
    <div id="wfList"><div class="empty-state"><div class="icon">⚡</div>No workflows yet</div></div>
  </div>
</div>

<!-- ─── PLAN ──────────────────────────────────────────────────── -->
<div class="panel" id="panel-plan">
  <div class="page-title">Pre-Execution Plan</div>
  <div class="page-sub">Generate and review the architecture plan before running</div>

  <div class="card" style="margin-bottom:16px;">
    <div class="card-title">Generate Plan</div>
    <div style="display:grid;gap:10px;">
      <div><label>Requirements</label><textarea id="planReq" rows="3" placeholder="Build a REST API with FastAPI, PostgreSQL, and JWT authentication"></textarea></div>
      <div class="form-row">
        <div><label>Stack</label><input id="planStack" placeholder="FastAPI, PostgreSQL"></div>
        <div><label>Features</label><input id="planFeatures" placeholder="auth, api, testing"></div>
      </div>
      <button class="btn" onclick="generatePlan()">🗺 Generate Plan</button>
    </div>
  </div>

  <div id="planOutput" style="display:none;">
    <div class="grid grid-2" style="margin-bottom:16px;" id="planStats"></div>
    <div class="card" style="margin-bottom:16px;">
      <div class="card-title">Execution Phases</div>
      <div id="planPhases"></div>
    </div>
    <div class="card">
      <div class="card-title">Parallel Groups (can run simultaneously)</div>
      <div id="planParallel"></div>
    </div>
    <div style="margin-top:16px;">
      <button class="btn" onclick="runFromPlan()">▶ Execute This Plan</button>
    </div>
  </div>
</div>

<!-- ─── MEMORY ─────────────────────────────────────────────────── -->
<div class="panel" id="panel-memory">
  <div class="page-title">Permanent Memory</div>
  <div class="page-sub">All past projects stored with vector similarity search</div>

  <div class="section-tabs">
    <div class="tab active" onclick="memTab(this,'list')">All Projects</div>
    <div class="tab" onclick="memTab(this,'search')">Search Similar</div>
    <div class="tab" onclick="memTab(this,'prefs')">Preferences</div>
  </div>

  <div id="memTabList">
    <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:12px;">
      <div style="font-size:13px;color:var(--text2);" id="memCount">Loading…</div>
      <button class="btn-outline btn-sm" onclick="loadMemory()">↻ Refresh</button>
    </div>
    <div id="memProjectList"></div>
  </div>

  <div id="memTabSearch" style="display:none;">
    <div class="search-row">
      <input id="memSearchQ" placeholder="Describe what you need… e.g. 'REST API with auth'">
      <button class="btn" onclick="searchMemory()">🔍 Search</button>
    </div>
    <div id="memSearchResults"></div>
  </div>

  <div id="memTabPrefs" style="display:none;">
    <div class="card">
      <div class="card-title">User Preferences</div>
      <div id="prefsContent">
        <textarea id="prefsJson" rows="8" style="font-family:monospace;font-size:12px;" placeholder='{"coding_style":"pep8","preferred_stack":"FastAPI","test_framework":"pytest"}'></textarea>
        <div style="margin-top:8px;"><button class="btn" onclick="savePrefs()">💾 Save Preferences</button></div>
      </div>
    </div>
  </div>
</div>

<!-- ─── VERIFY ─────────────────────────────────────────────────── -->
<div class="panel" id="panel-verify">
  <div class="page-title">Verification</div>
  <div class="page-sub">Post-build validation — syntax, tests, completeness</div>

  <div style="display:flex;gap:8px;margin-bottom:16px;">
    <input id="verifyWfId" placeholder="Workflow ID (or leave blank to run fresh check)">
    <button class="btn" onclick="runVerify()">✅ Run Verification</button>
  </div>

  <div id="verifyOutput" style="display:none;">
    <div class="grid grid-3" style="margin-bottom:16px;" id="verifyStats"></div>
    <div class="grid grid-2">
      <div class="card">
        <div class="card-title">Checks</div>
        <div id="verifyChecks"></div>
      </div>
      <div class="card">
        <div class="card-title">Completeness</div>
        <div id="verifyCompleteness"></div>
      </div>
    </div>
    <div class="card" style="margin-top:16px;" id="healingCard" style="display:none;">
      <div class="card-title" style="color:var(--yellow);">⚠ Healing Suggestions</div>
      <div id="healingSuggestions"></div>
    </div>
  </div>
</div>

<!-- ─── TERMINAL ──────────────────────────────────────────────── -->
<div class="panel" id="panel-terminal">
  <div class="page-title">Terminal</div>
  <div class="page-sub">Run shell commands on the orchestrator host</div>
  <div class="terminal">
    <div class="terminal-bar">
      <div class="term-dots">
        <div class="term-dot" style="background:#f85149"></div>
        <div class="term-dot" style="background:#d29922"></div>
        <div class="term-dot" style="background:#3fb950"></div>
      </div>
      <span style="font-size:11px;color:#8b949e;margin-left:4px;">AI Engineering OS — shell</span>
    </div>
    <div class="term-output" id="termOutput">
      <div class="cmd">AI Engineering OS v3.0 — type a command below</div>
    </div>
    <div class="term-input-row">
      <span class="term-prompt">$</span>
      <input class="term-input" id="termInput" placeholder="python3 --version" onkeydown="termKey(event)">
    </div>
  </div>
</div>

<!-- ─── FILES ─────────────────────────────────────────────────── -->
<div class="panel" id="panel-files">
  <div class="page-title">Files</div>
  <div class="page-sub">Browse workspace files</div>
  <div style="display:flex;gap:8px;margin-bottom:12px;">
    <input id="filePath" value="workspaces" style="max-width:280px;">
    <button class="btn-outline" onclick="loadFiles()">Browse</button>
    <label class="btn btn-sm" style="margin-left:auto;">📎 Upload <input type="file" style="display:none" onchange="uploadFile(this)"></label>
  </div>
  <div class="card">
    <div id="fileList"><div class="empty-state"><div class="icon">📁</div>Click Browse to view files</div></div>
  </div>
</div>

<!-- ─── CONFIG ─────────────────────────────────────────────────── -->
<div class="panel" id="panel-config">
  <div class="page-title">Configuration</div>
  <div class="page-sub">Environment variables and policy files</div>

  <div class="section-tabs">
    <div class="tab active" onclick="cfgTab(this,'env')">Environment</div>
    <div class="tab" onclick="cfgTab(this,'policy')">Policies</div>
  </div>

  <div id="cfgTabEnv">
    <div class="card" style="margin-bottom:12px;">
      <div class="card-title">.env Variables</div>
      <div id="envRows"></div>
      <button class="btn-ghost" onclick="addEnvRow()" style="margin-top:8px;">+ Add Variable</button>
    </div>
    <button class="btn" onclick="saveEnv()">💾 Save .env</button>
  </div>

  <div id="cfgTabPolicy" style="display:none;">
    <div class="card">
      <div class="card-title">Policy Files</div>
      <div style="margin-bottom:8px;"><select id="policySelect" onchange="loadPolicyContent()"><option value="">Select a policy…</option></select></div>
      <textarea id="policyContent" rows="20" style="font-family:monospace;font-size:12px;"></textarea>
      <div style="margin-top:8px;"><button class="btn" onclick="savePolicy()">💾 Save Policy</button></div>
    </div>
  </div>
</div>

</div><!-- /main -->
</div><!-- /layout -->

<div class="toast" id="toast"></div>

<script>
const API = '';
let theme = 'dark';
let currentWorkflowId = null;
let currentESS = null;
let elapsedInterval = null;
let elapsedStart = null;
let currentPlanData = null;

// ── Theme ────────────────────────────────────────────────────
function toggleTheme(){document.body.classList.toggle('light');theme=theme==='dark'?'light':'dark';}
function toggleSidebar(){document.getElementById('sidebar').classList.toggle('open');}

// ── Toast ───────────────────────────────────────────────────
function toast(msg,type='info'){
  const t=document.getElementById('toast');
  t.textContent=msg;t.className='toast show '+(type||'');
  setTimeout(()=>t.className='toast',3000);
}

// ── Panel navigation ────────────────────────────────────────
function showPanel(id){
  document.querySelectorAll('.panel').forEach(p=>p.classList.remove('active'));
  document.querySelectorAll('.nav-item').forEach(n=>n.classList.remove('active'));
  const panel=document.getElementById('panel-'+id);
  if(panel)panel.classList.add('active');
  document.querySelectorAll('.nav-item').forEach(n=>{
    if(n.textContent.trim().toLowerCase().includes(id.toLowerCase().replace('-',' ')))n.classList.add('active');
  });
  if(id==='agents')loadAgents();
  if(id==='workflows')loadWorkflows();
  if(id==='memory')loadMemory();
  if(id==='files')loadFiles();
  if(id==='config'){loadEnv();loadPolicies();}
  if(id==='overview')loadOverview();
}

// ── Health check ────────────────────────────────────────────
async function checkHealth(){
  try{
    const r=await fetch(`${API}/health`);
    const d=await r.json();
    const ok=d.status==='healthy';
    document.getElementById('healthDot').className='dot'+(ok?'':' offline');
    document.getElementById('healthLabel').textContent=ok?'Healthy':'Offline';
    document.getElementById('ovQueue').textContent=d.queue_size||0;
    document.getElementById('ovMem').textContent=d.memory_projects||0;
    document.getElementById('memBadge').textContent=d.memory_projects||0;
  }catch{
    document.getElementById('healthDot').className='dot offline';
    document.getElementById('healthLabel').textContent='Offline';
  }
}

// ── Overview ─────────────────────────────────────────────────
async function loadOverview(){
  checkHealth();
  try{
    const[wf,ag]=await Promise.all([fetch(`${API}/workflows`).then(r=>r.json()),fetch(`${API}/agents/status`).then(r=>r.json())]);
    document.getElementById('ovWf').textContent=wf.total||0;
    document.getElementById('wfBadge').textContent=wf.total||0;
    document.getElementById('ovAgents').textContent=(ag.online_count||0)+'/4';
    const recent=(wf.active_workflows||[]).slice(-5).reverse();
    if(recent.length){
      document.getElementById('recentWf').innerHTML=recent.map(w=>`
        <div class="wf-row">
          <div class="wf-id">${w.id.slice(0,8)}</div>
          <div class="wf-type">${w.type}</div>
          <div class="wf-status ${w.status}">${w.status}</div>
          <div style="margin-left:auto;font-size:11px;color:var(--text2)">${new Date(w.created_at*1000).toLocaleTimeString()}</div>
        </div>`).join('');
    }
  }catch(e){console.error(e);}
}

// ── Agents ───────────────────────────────────────────────────
async function loadAgents(){
  try{
    const d=await fetch(`${API}/agents/status`).then(r=>r.json());
    const caps={
      openhands:['Autonomous','Review','Debug'],
      aider:['Precision Edit','Refactor','Fix'],
      bolt:['Scaffold','UI Gen','Prototype'],
      replit:['Run','Test','Verify'],
    };
    const colors={openhands:'agent-openhands',aider:'agent-aider',bolt:'agent-bolt',replit:'agent-replit'};
    document.getElementById('agentGrid').innerHTML=Object.entries(d.agents||{}).map(([id,s])=>`
      <div class="card agent-card" id="agCard-${id}">
        <div class="agent-header">
          <div>
            <div class="agent-name">${id.charAt(0).toUpperCase()+id.slice(1)}</div>
            <div style="font-size:11px;color:var(--text2);">Port ${{openhands:3001,aider:3002,bolt:3003,replit:3004}[id]||'?'}</div>
          </div>
          <div class="status-pill ${s.healthy?'online':'offline'}">${s.healthy?'● Online':'● Offline'}</div>
        </div>
        <div class="info-row"><div class="info-key">Tasks run</div><div class="info-val">${s.task_count||0}</div></div>
        <div class="info-row"><div class="info-key">Errors</div><div class="info-val">${s.error_count||0}</div></div>
        <div class="info-row"><div class="info-key">Current task</div><div class="info-val">${s.current_task||'—'}</div></div>
        <div class="agent-caps">${(caps[id]||[]).map(c=>`<div class="cap-tag">${c}</div>`).join('')}</div>
      </div>`).join('');
  }catch(e){toast('Failed to load agents','error');}
}

// ── Workflows ────────────────────────────────────────────────
async function loadWorkflows(){
  try{
    const d=await fetch(`${API}/workflows`).then(r=>r.json());
    const wfs=d.active_workflows||[];
    document.getElementById('wfBadge').textContent=wfs.length;
    if(!wfs.length){document.getElementById('wfList').innerHTML='<div class="empty-state"><div class="icon">⚡</div>No workflows run yet</div>';return;}
    document.getElementById('wfList').innerHTML=wfs.slice().reverse().map(w=>`
      <div class="wf-row">
        <div><div class="wf-type">${w.type}</div><div class="wf-id">${w.id}</div></div>
        <div class="wf-status ${w.status}">${w.status}</div>
        ${w.complexity?`<div style="font-size:11px;color:var(--text2);">${w.complexity}</div>`:''}
        ${w.memory_stored?'<div style="font-size:11px;color:var(--green);">🧠 Stored</div>':''}
        <div style="margin-left:auto;display:flex;gap:6px;">
          <button class="btn-ghost btn-sm" onclick="viewWorkflow('${w.id}')">Details</button>
          <button class="btn-ghost btn-sm" onclick="showVerify('${w.id}')">Verify</button>
        </div>
      </div>`).join('');
  }catch(e){toast('Failed to load workflows','error');}
}

async function viewWorkflow(id){
  try{
    const d=await fetch(`${API}/workflows/${id}/status`).then(r=>r.json());
    const steps=d.results||[];
    alert(`Workflow: ${d.type}\nStatus: ${d.status}\nSteps: ${steps.length}\nComplexity: ${d.complexity||'?'}\nMemory stored: ${d.memory_stored?'Yes':'No'}\n\nSteps:\n${steps.map((s,i)=>`  ${i+1}. ${s.step_agent||s.agent_id} → ${s.action} [${s.status}]`).join('\n')}`);
  }catch(e){toast('Error loading workflow','error');}
}

function showVerify(id){
  document.getElementById('verifyWfId').value=id;
  showPanel('verify');
  runVerify();
}

async function runWorkflow(){
  const type=document.getElementById('wfType').value;
  const req=document.getElementById('wfReq').value.trim();
  if(!req){toast('Requirements are required','error');return;}
  const features=document.getElementById('wfFeatures').value.split(',').map(f=>f.trim()).filter(Boolean);
  const body={requirements:req,stack:document.getElementById('wfStack').value||null,features:features.length?features:null};

  document.getElementById('runBtn').disabled=true;
  document.getElementById('runBtn').textContent='Running…';
  showPhaseBar(true);
  startElapsed();
  connectSSE(null); // will be updated when workflow starts

  try{
    const r=await fetch(`${API}/workflows/${type}`,{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify(body)});
    const d=await r.json();
    if(!r.ok)throw new Error(d.detail||'Failed');
    stopElapsed();
    markPhase(4,'done');
    setProgress(100,'✅ All 5 phases complete');
    toast(`Workflow completed — ${d.steps_completed} steps`,'success');
    logStep('SUCCESS','Workflow complete — stored in memory as project '+d.project_id,'success');
    loadWorkflows();
    loadOverview();
  }catch(e){
    stopElapsed();
    toast('Error: '+e.message,'error');
    logStep('ERROR',e.message,'error');
  }finally{
    document.getElementById('runBtn').disabled=false;
    document.getElementById('runBtn').textContent='▶ Run Workflow';
  }
}

// ── SSE ──────────────────────────────────────────────────────
function connectSSE(workflowId){
  if(currentESS){currentESS.close();currentESS=null;}
  if(!workflowId)return;
  currentWorkflowId=workflowId;
  const sse=new EventSource(`${API}/stream/workflows/${workflowId}`);
  currentESS=sse;
  setSseStatus(true);
  const phaseMap={context:0,plan:1,execute:2,verify:3,learn:4};

  sse.addEventListener('connected',()=>{logStep('SSE','Stream connected','info');});
  sse.addEventListener('workflow_started',e=>{
    const d=JSON.parse(e.data).data;
    logStep('START',`Workflow started — ${d.steps} steps, complexity: ${d.complexity}`,'info');
    markPhase(0,'done');markPhase(1,'done');markPhase(2,'active');
    setProgress(20,'Phase 2: Execute');
  });
  sse.addEventListener('agent_started',e=>{
    const d=JSON.parse(e.data).data;
    logStep('→',`${d.agent} starting: ${d.action}`,'info');
    highlightAgent(d.agent,true);
  });
  sse.addEventListener('agent_completed',e=>{
    const d=JSON.parse(e.data).data;
    logStep('✓',`${d.agent} completed ${d.action} in ${d.duration_s}s — ${d.files} files`,'success');
    highlightAgent(d.agent,false);
    const pct=20+Math.round((d.step/(d.step+1))*40);
    setProgress(pct,`Step ${d.step+1} done`);
  });
  sse.addEventListener('agent_failed',e=>{
    const d=JSON.parse(e.data).data;
    logStep('✗',`${d.agent} failed: ${d.summary}`,'error');
    highlightAgent(d.agent,false);
  });
  sse.addEventListener('step_progress',e=>{
    const d=JSON.parse(e.data).data;
    logStep('…',d.message,'warn');
    if(d.percent!==undefined)setProgress(20+d.percent*0.4,d.message);
  });
  sse.addEventListener('workflow_completed',e=>{
    const d=JSON.parse(e.data).data;
    logStep('✅',`All steps done in ${d.duration_s}s`,'success');
    markPhase(2,'done');markPhase(3,'active');
    setProgress(80,'Phase 3: Verify');
    setTimeout(()=>{markPhase(3,'done');markPhase(4,'active');setProgress(95,'Phase 4: Learn');},1000);
    setSseStatus(false);sse.close();
  });
  sse.addEventListener('workflow_failed',e=>{
    const d=JSON.parse(e.data).data;
    logStep('✗','Workflow failed: '+d.error,'error');
    setSseStatus(false);sse.close();
  });
  sse.addEventListener('stream_closed',()=>{setSseStatus(false);sse.close();});
  sse.onerror=()=>{setSseStatus(false);};
}

function setSseStatus(connected){
  document.getElementById('sseDot').className='sse-dot'+(connected?' connected':'');
  document.getElementById('sseLabel').textContent=connected?'SSE Live':'SSE';
}

function showPhaseBar(show){
  document.getElementById('phaseBar').style.display=show?'':'none';
  document.getElementById('sseLogWrap').style.display=show?'':'none';
  if(show){[0,1,2,3,4].forEach(i=>document.getElementById('ps'+i).className='phase-step');}
}

function markPhase(n,state){
  const el=document.getElementById('ps'+n);
  if(!el)return;
  el.className='phase-step '+state;
  el.querySelector('.phase-dot').textContent=state==='done'?'✓':n;
}

function setProgress(pct,label){
  document.getElementById('wfProgressFill').style.width=pct+'%';
  document.getElementById('wfProgressLabel').textContent=label;
}

function logStep(prefix,msg,type){
  const log=document.getElementById('stepLog');
  const t=new Date().toLocaleTimeString('en',{hour12:false,hour:'2-digit',minute:'2-digit',second:'2-digit'});
  const div=document.createElement('div');
  div.className='log-entry';
  div.innerHTML=`<span class="log-time">${t}</span><span class="log-msg ${type||''}">[${prefix}] ${msg}</span>`;
  log.appendChild(div);
  log.scrollTop=log.scrollHeight;
}

function highlightAgent(agentId,on){
  const card=document.getElementById('agCard-'+agentId);
  if(card){card.classList.toggle('working',on);const pill=card.querySelector('.status-pill');if(pill&&on)pill.className='status-pill working';}
}

function startElapsed(){
  elapsedStart=Date.now();
  document.getElementById('phaseTitle').textContent='Executing workflow…';
  elapsedInterval=setInterval(()=>{
    const s=Math.round((Date.now()-elapsedStart)/1000);
    document.getElementById('elapsedTimer').textContent=s+'s';
  },1000);
}
function stopElapsed(){clearInterval(elapsedInterval);}

// ── Plan ─────────────────────────────────────────────────────
async function generatePlan(){
  const req=document.getElementById('planReq').value.trim();
  if(!req){toast('Requirements required','error');return;}
  const body={requirements:req,stack:document.getElementById('planStack').value||null,features:document.getElementById('planFeatures').value.split(',').map(f=>f.trim()).filter(Boolean)||null};
  try{
    const d=await fetch(`${API}/plan/generate`,{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify(body)}).then(r=>r.json());
    currentPlanData=d;
    renderPlan(d);
    document.getElementById('planOutput').style.display='';
  }catch(e){toast('Plan error: '+e.message,'error');}
}

function renderPlan(d){
  const p=d.plan;const s=d.summary;
  document.getElementById('planStats').innerHTML=`
    <div class="card"><div class="card-title">Complexity</div><div class="stat-val">${s.complexity}</div></div>
    <div class="card"><div class="card-title">Phases</div><div class="stat-val">${s.phases}</div></div>
    <div class="card"><div class="card-title">Est. Files</div><div class="stat-val">${s.estimated_files}</div></div>
    <div class="card"><div class="card-title">Est. Hours</div><div class="stat-val">${s.estimated_hours}h</div></div>`;
  document.getElementById('planPhases').innerHTML=(p.phases||[]).map((ph,i)=>`
    <div class="plan-phase">
      <span class="plan-agent agent-${ph.agent}">${ph.agent}</span>
      <div style="flex:1">
        <div style="font-weight:600;font-size:13px;">${ph.name} — ${ph.action}</div>
        <div style="font-size:11px;color:var(--text2);">${ph.description}</div>
        <div style="font-size:11px;color:var(--text2);margin-top:2px;">Files: ${(ph.files_to_create||[]).slice(0,4).join(', ')}</div>
      </div>
      <div style="font-size:11px;color:var(--text2);">${ph.estimated_time}</div>
    </div>`).join('');
  const pg=d.resolved_order.parallel_groups||[];
  document.getElementById('planParallel').innerHTML=pg.map((grp,i)=>`
    <div style="display:flex;align-items:center;gap:8px;padding:8px 0;border-bottom:1px solid var(--border)">
      <div style="font-size:11px;color:var(--text2);width:50px;">Group ${i+1}</div>
      <div style="display:flex;gap:6px;flex-wrap:wrap">${grp.map(n=>`<span class="cap-tag">${n}</span>`).join('')}</div>
    </div>`).join('')||'<div class="empty-state">Sequential execution</div>';
}

function runFromPlan(){
  if(!currentPlanData)return;
  const p=currentPlanData.plan;
  document.getElementById('wfReq').value=p.requirements||'';
  document.getElementById('wfStack').value=(p.detected_stack||[]).join(', ');
  document.getElementById('wfFeatures').value=(p.detected_features||[]).join(', ');
  showPanel('workflows');
  toast('Plan loaded — click Run Workflow to execute');
}

// ── Memory ───────────────────────────────────────────────────
function memTab(btn,tab){
  document.querySelectorAll('#panel-memory .tab').forEach(t=>t.classList.remove('active'));
  btn.classList.add('active');
  document.getElementById('memTabList').style.display=tab==='list'?'':'none';
  document.getElementById('memTabSearch').style.display=tab==='search'?'':'none';
  document.getElementById('memTabPrefs').style.display=tab==='prefs'?'':'none';
}

async function loadMemory(){
  try{
    const d=await fetch(`${API}/memory/projects`).then(r=>r.json());
    const projects=d.projects||[];
    document.getElementById('memCount').textContent=`${projects.length} projects in permanent memory`;
    document.getElementById('memBadge').textContent=projects.length;
    if(!projects.length){document.getElementById('memProjectList').innerHTML='<div class="empty-state"><div class="icon">🧠</div>No projects in memory yet — run a workflow to start learning</div>';return;}
    document.getElementById('memProjectList').innerHTML=projects.map(p=>`
      <div class="memory-card" onclick="viewProject('${p.id}')">
        <div class="memory-name">${p.name}</div>
        <div class="memory-desc">${p.description}</div>
        <div class="memory-meta">
          ${(p.stack||[]).slice(0,4).map(s=>`<span class="meta-tag">${s}</span>`).join('')}
          <span class="meta-tag">${p.complexity||'?'}</span>
          <span style="margin-left:auto;font-size:11px;color:var(--text2);">${new Date((p.updated_at||0)*1000).toLocaleDateString()}</span>
        </div>
      </div>`).join('');
  }catch(e){toast('Memory load error','error');}
}

async function viewProject(id){
  try{
    const p=await fetch(`${API}/memory/projects/${id}`).then(r=>r.json());
    alert(`Project: ${p.name}\n\nDescription: ${p.description}\nStack: ${(p.stack||[]).join(', ')}\nComplexity: ${p.complexity}\nDecisions:\n${(p.decisions||[]).slice(0,5).join('\n')}\nPatterns: ${(p.patterns||[]).join(', ')}`);
  }catch(e){toast('Error loading project','error');}
}

async function searchMemory(){
  const q=document.getElementById('memSearchQ').value.trim();
  if(!q){toast('Enter a search query','error');return;}
  try{
    const d=await fetch(`${API}/memory/search`,{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({requirements:q})}).then(r=>r.json());
    const results=d.results||[];
    document.getElementById('memSearchResults').innerHTML=results.length?results.map(p=>`
      <div class="memory-card">
        <div class="memory-name">${p.name}<span class="sim-score">${(p._similarity_score*100).toFixed(0)}% match</span></div>
        <div class="memory-desc">${p.description}</div>
        <div class="memory-meta">${(p.stack||[]).slice(0,4).map(s=>`<span class="meta-tag">${s}</span>`).join('')}</div>
      </div>`).join(''):'<div class="empty-state"><div class="icon">🔍</div>No similar projects found</div>';
  }catch(e){toast('Search error','error');}
}

async function savePrefs(){
  try{
    const prefs=JSON.parse(document.getElementById('prefsJson').value||'{}');
    await fetch(`${API}/memory/preferences`,{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({preferences:prefs})});
    toast('Preferences saved','success');
  }catch(e){toast('Invalid JSON or save error','error');}
}

// ── Verify ───────────────────────────────────────────────────
async function runVerify(){
  const wfId=document.getElementById('verifyWfId').value.trim();
  try{
    const url=wfId?`${API}/verify/${wfId}`:`${API}/verify/latest`;
    const d=await fetch(wfId?`${API}/verify/${wfId}`:`${API}/verify/noop`).then(r=>r.json()).catch(async()=>{
      // fallback: trigger a fresh verify
      return fetch(`${API}/verify/_fresh`,{method:'GET'}).then(r=>r.json()).catch(()=>null);
    });
    if(!d){toast('No verification data available','error');return;}
    renderVerify(d);
    document.getElementById('verifyOutput').style.display='';
  }catch(e){toast('Verify error: '+e.message,'error');}
}

function renderVerify(d){
  const build=d.build||{};const comp=d.completeness||{};const overall=d.overall_passed;
  document.getElementById('verifyStats').innerHTML=`
    <div class="card"><div class="card-title">Overall</div><div class="stat-val" style="color:${overall?'var(--green)':'var(--red)'};">${overall?'✅ PASS':'❌ FAIL'}</div></div>
    <div class="card"><div class="card-title">Build</div><div class="stat-val" style="color:${build.passed?'var(--green)':'var(--red)'};">${build.passed?'Pass':'Fail'}</div><div class="stat-sub">${build.duration_s||0}s</div></div>
    <div class="card"><div class="card-title">Completeness</div><div class="stat-val">${comp.percentage||0}%</div><div class="stat-sub">${comp.found_features?.length||0}/${comp.required_features?.length||0} features</div></div>`;

  const checks=build.results||{};
  document.getElementById('verifyChecks').innerHTML=Object.entries(checks).map(([k,v])=>`
    <div class="verify-row">
      <div class="verify-label">${k.replace('_',' ')}</div>
      <div class="verify-result ${v.skipped?'skip':v.passed?'pass':'fail'}">${v.skipped?'Skipped':v.passed?'✓ Pass':'✗ Fail'}</div>
    </div>`).join('')||'<div style="color:var(--text2);font-size:13px;">No build results yet</div>';

  document.getElementById('verifyCompleteness').innerHTML=`
    <div class="info-row"><div class="info-key">Files built</div><div class="info-val">${comp.file_count||0}</div></div>
    ${(comp.found_features||[]).map(f=>`<div class="info-row"><div class="info-key" style="color:var(--green);">✓ ${f}</div></div>`).join('')}
    ${(comp.missing_features||[]).map(f=>`<div class="info-row"><div class="info-key" style="color:var(--red);">✗ ${f}</div></div>`).join('')}
    <div style="margin-top:8px;font-size:12px;color:var(--text2);">${comp.report||''}</div>`;

  const suggestions=build.healing_suggestions||[];
  if(suggestions.length){
    document.getElementById('healingCard').style.display='';
    document.getElementById('healingSuggestions').innerHTML=suggestions.map(s=>`<div style="padding:4px 0;font-size:13px;">• ${s}</div>`).join('');
  }
}

// ── Terminal ─────────────────────────────────────────────────
function termKey(e){if(e.key==='Enter')runTermCmd();}
async function runTermCmd(){
  const inp=document.getElementById('termInput');
  const cmd=inp.value.trim();if(!cmd)return;
  const out=document.getElementById('termOutput');
  out.innerHTML+=`<div><span class="cmd">$ ${cmd}</span></div>`;
  inp.value='';
  try{
    const d=await fetch(`${API}/terminal`,{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({command:cmd})}).then(r=>r.json());
    if(d.stdout)out.innerHTML+=`<div class="ok">${escHtml(d.stdout)}</div>`;
    if(d.stderr)out.innerHTML+=`<div class="err">${escHtml(d.stderr)}</div>`;
  }catch(e){out.innerHTML+=`<div class="err">Request failed: ${e.message}</div>`;}
  out.scrollTop=out.scrollHeight;
}
function escHtml(s){return s.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');}

// ── Files ─────────────────────────────────────────────────────
async function loadFiles(){
  const path=document.getElementById('filePath').value||'workspaces';
  try{
    const d=await fetch(`${API}/files?path=${encodeURIComponent(path)}`).then(r=>r.json());
    if(!d.entries.length){document.getElementById('fileList').innerHTML='<div class="empty-state"><div class="icon">📁</div>No files found</div>';return;}
    document.getElementById('fileList').innerHTML=d.entries.map(f=>`
      <div class="wf-row">
        <div>${f.type==='dir'?'📁':'📄'} ${f.path}</div>
        ${f.size!=null?`<div style="margin-left:auto;font-size:11px;color:var(--text2);">${(f.size/1024).toFixed(1)}KB</div>`:''}
      </div>`).join('');
  }catch(e){toast('File load error','error');}
}

async function uploadFile(input){
  const file=input.files[0];if(!file)return;
  const fd=new FormData();fd.append('file',file);
  try{
    const d=await fetch(`${API}/files/upload`,{method:'POST',body:fd}).then(r=>r.json());
    toast(`Uploaded ${d.filename}`,'success');loadFiles();
  }catch(e){toast('Upload failed','error');}
}

// ── Config ────────────────────────────────────────────────────
function cfgTab(btn,tab){
  document.querySelectorAll('#panel-config .tab').forEach(t=>t.classList.remove('active'));
  btn.classList.add('active');
  document.getElementById('cfgTabEnv').style.display=tab==='env'?'':'none';
  document.getElementById('cfgTabPolicy').style.display=tab==='policy'?'':'none';
}

let envData={};
async function loadEnv(){
  try{
    const d=await fetch(`${API}/env`).then(r=>r.json());
    envData={...d.variables};renderEnvRows();
  }catch(e){}
}
function renderEnvRows(){
  document.getElementById('envRows').innerHTML=Object.entries(envData).map(([k,v])=>`
    <div class="env-row">
      <input class="env-key" value="${escHtml(k)}" onchange="envKeyChange(this,'${k}')">
      <input class="env-val" value="${escHtml(v)}" onchange="envData['${k}']=this.value">
      <button class="env-del" onclick="deleteEnvRow('${k}')">✕</button>
    </div>`).join('');
}
function addEnvRow(){envData['NEW_KEY']='';renderEnvRows();}
function deleteEnvRow(k){delete envData[k];renderEnvRows();}
function envKeyChange(el,oldKey){const nk=el.value;envData[nk]=envData[oldKey];delete envData[oldKey];}
async function saveEnv(){
  try{
    await fetch(`${API}/env`,{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({variables:envData})});
    toast('Saved .env','success');
  }catch(e){toast('Save failed','error');}
}

let policiesData={};
async function loadPolicies(){
  try{
    const d=await fetch(`${API}/policies`).then(r=>r.json());
    policiesData=d.policies||{};
    const sel=document.getElementById('policySelect');
    sel.innerHTML='<option value="">Select a policy…</option>'+Object.keys(policiesData).map(k=>`<option value="${k}">${k}</option>`).join('');
  }catch(e){}
}
function loadPolicyContent(){
  const k=document.getElementById('policySelect').value;
  if(!k)return;
  document.getElementById('policyContent').value=JSON.stringify(policiesData[k]||{},null,2);
}
async function savePolicy(){
  const k=document.getElementById('policySelect').value;
  if(!k){toast('Select a policy first','error');return;}
  try{
    const content=JSON.parse(document.getElementById('policyContent').value);
    await fetch(`${API}/policies`,{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({name:k,content})});
    toast('Policy saved','success');
  }catch(e){toast('Invalid JSON or save error','error');}
}

// ── Global refresh ───────────────────────────────────────────
function refreshAll(){checkHealth();loadOverview();}

// ── Init ─────────────────────────────────────────────────────
checkHealth();
loadOverview();
setInterval(checkHealth,15000);

// Auto-connect SSE for any running workflow
(async()=>{
  try{
    const d=await fetch(`${API}/workflows`).then(r=>r.json());
    const running=(d.active_workflows||[]).find(w=>w.status==='running');
    if(running){connectSSE(running.id);showPanel('workflows');}
  }catch(e){}
})();
</script>
</body>
</html>
