{
  "workflows": {
    "full-app-generation": {
      "steps": [
        {"agent": "bolt", "action": "scaffold", "timeout": 300},
        {"agent": "aider", "action": "edit", "timeout": 300},
        {"agent": "replit", "action": "test", "timeout": 300},
        {"agent": "openhands", "action": "review", "timeout": 300}
      ],
      "on_failure": "heal_and_retry",
      "max_retries": 2
    },
    "refactoring": {
      "steps": [
        {"agent": "openhands", "action": "analyze", "timeout": 300},
        {"agent": "aider", "action": "refactor", "timeout": 300},
        {"agent": "replit", "action": "test", "timeout": 300}
      ],
      "on_failure": "heal_and_retry",
      "max_retries": 2
    },
    "bug-fixing": {
      "steps": [
        {"agent": "openhands", "action": "diagnose", "timeout": 300},
        {"agent": "aider", "action": "fix", "timeout": 300},
        {"agent": "replit", "action": "verify", "timeout": 300}
      ],
      "on_failure": "heal_and_retry",
      "max_retries": 3
    },
    "prototyping": {
      "steps": [
        {"agent": "bolt", "action": "generate", "timeout": 120},
        {"agent": "replit", "action": "preview", "timeout": 120}
      ],
      "on_failure": "skip_and_continue",
      "max_retries": 1
    }
  }
}
