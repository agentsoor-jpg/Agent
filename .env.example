# ============================================================
# AI Engineering OS - Environment Variables
# ============================================================

# -------------------- App --------------------
APP_NAME=AI Engineering OS
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8080

# -------------------- API Keys --------------------
OPENAI_API_KEY=your_openai_api_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here
GOOGLE_API_KEY=your_google_api_key_here

# -------------------- Redis --------------------
REDIS_URL=redis://localhost:6379
REDIS_CHANNEL_TASKS=tasks
REDIS_CHANNEL_EVENTS=events

# -------------------- ChromaDB --------------------
CHROMA_DB_PATH=./memory/chroma_db

# -------------------- Docker --------------------
DOCKER_HOST=unix://var/run/docker.sock
DOCKER_NETWORK=aios_network
DOCKER_TIMEOUT=300

# -------------------- Git --------------------
GIT_DEFAULT_BRANCH=main

# -------------------- System Limits --------------------
MAX_PARALLEL_AGENTS=3
MAX_RETRY_ATTEMPTS=2
MAX_COST_PER_RUN=5.0
MAX_RUNTIME_PER_TASK=15
HUMAN_APPROVAL_ENABLED=true

# -------------------- Logging --------------------
LOG_LEVEL=INFO
LOG_FILE=logs/system.log

# -------------------- Agent Endpoints --------------------
OPENHANDS_API=http://localhost:3001
AIDER_API=http://localhost:3002
BOLT_API=http://localhost:3003
REPLIT_API=http://localhost:3004
