# ============================================================
# OpenHands Agent - Pull Method
# ============================================================
# Uses the official public OpenHands image from GitHub Container Registry
# This is the RECOMMENDED method for most users
#
# Image source: ghcr.io/all-hands-ai/openhands
# ============================================================

FROM ghcr.io/all-hands-ai/openhands:latest

# Expose the agent API port
EXPOSE 3001

# Health check
HEALTHCHECK --interval=30s --timeout=10s --start-period=60s --retries=3 \
    CMD curl -f http://localhost:3001/health || exit 1

# Default command - start OpenHands in API mode
CMD ["python", "-m", "openhands", "--http-server", "--port", "3001"]
